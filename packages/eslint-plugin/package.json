{
  "name": "@stylistic/eslint-plugin",
  "type": "module",
  "version": "6.0.0-beta.3",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/eslint-stylistic/eslint-stylistic#readme",
  "repository": {
    "directory": "packages/eslint-plugin",
    "type": "git",
    "url": "git+https://github.com/eslint-stylistic/eslint-stylistic.git"
  },
  "bugs": {
    "url": "https://github.com/eslint-stylistic/eslint-stylistic/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/dts/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./define-config-support": {
      "types": "./dist/dts/define-config-support.d.ts"
    },
    "./rule-options": {
      "types": "./dist/dts/rule-options.d.ts"
    },
    "./rules/*": "./dist/rules/*"
  },
  "types": "./dist/dts/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "oxlint": "^1.55.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint-community/eslint-utils": "catalog:prod",
    "@typescript-eslint/types": "catalog:prod",
    "@typescript-eslint/visitor-keys": "catalog:prod",
    "espree": "catalog:prod",
    "picomatch": "catalog:prod"
  },
  "inlinedDependencies": {
    "@typescript-eslint/utils": "8.56.1",
    "escape-string-regexp": "5.0.0"
  }
}
